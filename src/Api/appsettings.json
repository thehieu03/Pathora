{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "ZiggyCreatures.Caching.Fusion": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Auth": {
    "DisableAuthorization": false
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "https://localhost:3000"]
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "AppConfig": {
    "ServiceName": "Panthora API",
    "IncludeInnerException": false,
    "IncludeExceptionStackTrace": false
  },
  "SwaggerGen": {
    "Title": "Panthora Backend API",
    "Version": "v1",
    "Description": "API documentation for Panthora backend services",
    "ContactName": "Panthora Team",
