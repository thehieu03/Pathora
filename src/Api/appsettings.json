{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "ZiggyCreatures.Caching.Fusion": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Auth": {
    "DisableAuthorization": false
  },
  "Dev": {
    "EnableDevEndpoints": false
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=Pathora;Username=postgres;Password=REPLACE_ME"
  },
  "AppConfig": {
    "ServiceName": "Panthora API",
    "IncludeInnerException": false,
    "IncludeExceptionStackTrace": false
  },
  "SwaggerGen": {
    "Title": "Panthora Backend API",
    "Version": "v1",
    "Description": "API documentation for Panthora backend services",
    "ContactName": "Panthora Team",
    "ContactEmail": "hieunthe171211@gmail.com",
    "dev": "Nguyen The Hieu",
    "ContactUrl": "https://www.facebook.com/the.hieu.5074"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "REPLACE_ME",
    "SecretKey": "REPLACE_ME",
    "UseSSL": "false",
    "DefaultBucket": "panthora",
    "PublicUrl": "http://localhost:9000"
  },
  "Jwt": {
    "Secret": "REPLACE_ME_WITH_AT_LEAST_64_CHARACTER_SECRET_KEY",
    "Issuer": "http://localhost:8080",
    "Audience": "http://localhost:8080",
    "ExpireInMinutes": 15
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  }
}
