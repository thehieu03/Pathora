# Pathora Backend - Environment Variables
# Copy this file to .env and fill in the values
# ASP.NET Core reads these automatically with __ as section separator

# Database
ConnectionStrings__Default=Host=pathora-db.duckdns.org;Port=443;Database=postgres;Username=postgres;Password=YOUR_CLOUD_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Redis
Redis__ConnectionString=localhost:6379

# JWT Authentication
Jwt__Secret=YOUR_JWT_SECRET_KEY_AT_LEAST_64_CHARACTERS_LONG

# Cloudinary File Storage
Cloudinary__CloudName=YOUR_CLOUDINARY_CLOUD_NAME
Cloudinary__ApiKey=YOUR_CLOUDINARY_API_KEY
Cloudinary__ApiSecret=YOUR_CLOUDINARY_API_SECRET
Cloudinary__DefaultFolder=panthora

# Email (SMTP)
Mail__Username=YOUR_EMAIL@gmail.com
Mail__Password=YOUR_APP_PASSWORD

# Google OAuth
Authentication__Google__ClientId=YOUR_GOOGLE_CLIENT_ID
Authentication__Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# SePay/PayOS Payment Gateway
Payment__Account=0378175727
Payment__Bank=MB
Payment__AuthenticationKey=YOUR_SEPAY_API_KEY
Payment__WebhookSecret=YOUR_SEPAY_WEBHOOK_SECRET
# PayOS API URL (for checkout redirect)
Payment__PayOSApiUrl=https://api-merchant.payos.vn

# Dev endpoints (only used in Development environment)
Dev__EnableDevEndpoints=false

# Application URLs
AppConfig__FrontendBaseUrl=http://localhost:3001
AppConfig__SwaggerBaseUrl=https://pathora-be.duckdns.org/swagger/index.html
