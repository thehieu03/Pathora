# ===========================================
# PATHORA - Environment Variables cho Docker
# ===========================================
# Copy từ .env.example và điền giá trị thật
# Chạy: docker-compose up --build

# === Database (PostgreSQL - thay bằng DB cloud của bạn) ===
DB_CONNECTION_STRING=Host=YOUR_DB_HOST;Port=5432;Database=PPPathora;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# === Redis ===
REDIS_CONNECTION_STRING=redis:6379

# === JWT Secret (phải >= 64 ký tự) ===
JWT_SECRET=YOUR_VERY_LONG_JWT_SECRET_KEY_AT_LEAST_64_CHARACTERS_IN_PRODUCTION_HERE

# === SePay Payment Gateway ===
SEPAY_ACCOUNT=0378175727
SEPAY_BANK=MB
SEPAY_API_KEY=YOUR_SEPAY_API_KEY
SEPAY_WEBHOOK_SECRET=YOUR_SEPAY_WEBHOOK_SECRET

# === PayOS Payment Gateway ===
PAYOS_API_URL=https://api-merchant.payos.vn
PAYOS_API_KEY=YOUR_PAYOS_API_KEY
PAYOS_CLIENT_ID=YOUR_PAYOS_CLIENT_ID
PAYOS_CHECKSUM_KEY=YOUR_PAYOS_CHECKSUM_KEY

# === URLs (cập nhật sau khi deploy) ===
API_BASE_URL=http://api:8080
FRONTEND_BASE_URL=http://localhost:3001

# === Payment Display ===
BANK_NAME=MBBank (MB)
BANK_ACCOUNT=0378175727
BANK_HOLDER=PATHORA TRAVEL
